# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local for local development
# For Vercel deployment, set these in the Vercel dashboard under Settings > Environment Variables

# Backend API URL
# Local development:
VITE_API_BASE_URL=http://localhost:8080
# Production (replace with your actual Render URL after deployment):
# VITE_API_BASE_URL=https://ai-engineering-backend.onrender.com

# OpenRouter API Key (get one free at https://openrouter.ai)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here
